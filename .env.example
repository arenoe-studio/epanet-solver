# Copy to .env.local for local development. Do not commit secrets.

# Phase 2+
# DATABASE_URL="postgresql://..."

# Phase 2+
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="replace-me"

# Auth email (required for verification codes)
# RESEND_API_KEY="replace-me"
# Optional override for "from" address
# AUTH_EMAIL_FROM="EPANET Solver <onboarding@resend.dev>"
# Require OTP (verification code) on every login (default: true)
# AUTH_REQUIRE_LOGIN_OTP="true"
# OTP TTL in minutes (default: 10)
# AUTH_OTP_TTL_MINUTES="10"

# Phase 3 (optional for local dev)
# PYTHON_API_URL="http://localhost:8000/api/analyze_python"

# Phase 4+
# MIDTRANS_SERVER_KEY="replace-me"
# MIDTRANS_IS_PRODUCTION="false"
# MIDTRANS_CLIENT_KEY="replace-me"              # server-side
# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="replace-me"  # Snap.js (client-side)

# PAYMENT
# - midtrans: use Midtrans Snap (requires MIDTRANS_* env vars)
# - qris_static: use static QRIS (GoPay Merchant) and manual admin confirmation
PAYMENT_PROVIDER="qris_static"

# QRIS static (GoPay Merchant)
# Put a public URL or a path to a public asset (e.g. "/pay/qris-gopay.png")
NEXT_PUBLIC_QRIS_STATIC_QR_IMAGE_URL="/pay/qris-static.png"
# Optional display label shown in UI (e.g. "QRIS (GoPay)")
NEXT_PUBLIC_QRIS_STATIC_LABEL="QRIS (GoPay)"

# Optional: notify admin when user creates a pending transaction
PAYMENT_ADMIN_EMAIL="admin@example.com"

# Public business info (for Midtrans website criteria)
# NEXT_PUBLIC_BUSINESS_NAME="EPANET Solver"
# NEXT_PUBLIC_BUSINESS_EMAIL="support@epanet-solver.com"
# NEXT_PUBLIC_BUSINESS_PHONE="+62..."
# NEXT_PUBLIC_BUSINESS_ADDRESS="City, Province, Indonesia"

# Phase 4+ (payment emails also use Resend)
# RESEND_API_KEY="replace-me"

# Phase 6 (optional - rate limiting via Upstash)
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# Dev convenience (optional)
# Comma-separated emails that should be treated as admins, e.g.:
# ADMIN_EMAILS="arenoe.studio@gmail.com"
# When enabled, admins can run analyses without token deductions (default: true in dev, false in prod).
# ADMIN_BYPASS_TOKENS="true"
