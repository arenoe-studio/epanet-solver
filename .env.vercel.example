# Copy to .env.vercel (do not commit secrets).
# This file is meant to be pushed to Vercel without re-typing.
#
# Tips:
# - Use the Vercel project domain for NEXTAUTH_URL (e.g. https://yourapp.vercel.app)
# - MIDTRANS_IS_PRODUCTION must be "true" for production

DATABASE_URL=
NEXTAUTH_URL=
NEXTAUTH_SECRET=

PYTHON_API_URL=

# Python solver tuning
# - For Vercel serverless, keep these conservative.
# - For a dedicated backend (laptop/VPS), you can increase them.
EPANET_SOLVER_MAX_ITERATIONS=15
EPANET_SOLVER_TIME_BUDGET_S=20
# EPANET_SOLVER_SIMULATOR=auto   # auto | epyt | epanet | wntr
# EPANET_SOLVER_REQUIRE_EPANET=1 # default 1; set to 0 to allow WNTR fallback

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# PAYMENT
PAYMENT_PROVIDER=qris_static
NEXT_PUBLIC_QRIS_STATIC_QR_IMAGE_URL=
NEXT_PUBLIC_QRIS_STATIC_LABEL=
PAYMENT_ADMIN_EMAIL=

RESEND_API_KEY=
AUTH_EMAIL_FROM=
AUTH_REQUIRE_LOGIN_OTP=true
AUTH_OTP_TTL_MINUTES=10

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

ADMIN_EMAILS=
ADMIN_BYPASS_TOKENS=false

NEXT_PUBLIC_BUSINESS_NAME=EPANET Solver
NEXT_PUBLIC_BUSINESS_EMAIL=support@epanet-solver.com
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_ADDRESS=
